{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExecutionConstitutionContract",
  "type": "object",
  "properties": {
    "authority_origin": { "type": "string" },
    "intent_class": { "type": "string" },
    "risk_class": { "type": "string" },
    "admissibility_state": { "type": "string", "enum": ["pending", "admissible", "inadmissible"] },
    "signer_chain": { "type": "array", "items": { "type": "string" } },
    "consequence_domain": { "type": "string" }
  },
  "required": ["authority_origin", "intent_class", "risk_class", "admissibility_state", "signer_chain", "consequence_domain"]
}
