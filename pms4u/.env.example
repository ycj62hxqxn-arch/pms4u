APP_NAME=pms4u
APP_ENV=development
APP_PORT=3000

# Default YAI UI calls the integrated Next route: /api/yai.
# Set NEXT_PUBLIC_YAI_API_BASE only when running the standalone server.
YAI_HOST=127.0.0.1
YAI_PORT=3001
YAI_ALLOWED_ORIGIN=http://127.0.0.1:3000
# NEXT_PUBLIC_YAI_API_BASE=http://127.0.0.1:3001

LOG_LEVEL=info
SERVICE_VERSION=phase-1
AUTH_MODE=disabled
JWT_SECRET=changeme
DATABASE_URL=
REDIS_URL=

# Leave OPENAI_API_KEY empty to demo the local MCV fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
